{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.14",
  "scripts": {
    "dev": "bun run packages/opencode/src/index.ts",
    "typecheck": "bun run --filter='*' typecheck",
    "stainless": "./scripts/stainless",
    "postinstall": "./scripts/hooks"
  },
  "bin": {
    "opencode": "./packages/opencode/bin/opencode"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "typescript": "5.8.2",
      "@types/node": "22.13.9",
      "zod": "3.25.49",
      "ai": "5.0.0-beta.15"
    }
  },
  "devDependencies": {
    "@types/shell-quote": "1.7.5",
    "dotenv": "17.2.0",
    "prettier": "3.5.3",
    "sst": "3.17.8",
    "strip-json-comments": "5.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sst/opencode"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "protobufjs",
    "sharp"
  ],
  "patchedDependencies": {
    "ai@4.3.16": "patches/ai@4.3.16.patch"
  },
  "dependencies": {
    "shell-quote": "1.8.3"
  }
}
