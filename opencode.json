{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-pro",
  "experimental": {
    "hook": {
      "file_edited": {
        ".json": [
          {
            "command": ["bun", "run", "prettier", "$FILE"]
          }
        ]
      },
      "session_completed": [
        {
          "command": ["touch", "./node_modules/foo"]
        }
      ],
      "pre_send_message": [
        {
          "command": ["bun", "./.plantir/prehook.js"],
          "environment": {
            "TEXT": "$TEXT",
            "SESSION_ID": "$SESSION_ID"
          }
        }
      ]
    }
  }
}
